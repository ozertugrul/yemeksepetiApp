# ── PostgreSQL (Supabase) ─────────────────────────────────────────────────────
# Supabase → Settings → Database → Connection string → URI (asyncpg formatı)
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── Local Supabase/Postgres (Docker) ─────────────────────────────────────────
# docker compose up -d --build
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=postgres
# Local compose API bu URL'i kullanır (DATABASE_URL'den bağımsız):
LOCAL_DATABASE_URL=postgresql+asyncpg://postgres:postgres@supabase-db:5432/postgres
# Local çalıştırmak istersen DATABASE_URL'i buna çek:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@supabase-db:5432/postgres

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
# Güçlü ve uzun bir secret kullanın (production).
JWT_SECRET_KEY=change-this-jwt-secret
JWT_SECRET=change-this-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
ANON_KEY=
SERVICE_ROLE_KEY=

# ── Feature Flags (rollback için) ─────────────────────────────────────────────
USE_SQL_BACKEND=true
USE_EMBEDDINGS=false

# ── API ───────────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1
DEBUG=false

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=ozertuu/yemeksepeti-MiniLM-L12-v2
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_SEQ_LENGTH=256

# ── Collaborative Filtering ──────────────────────────────────────────────────
CF_LOOKBACK_DAYS=90
CF_MIN_SIMILARITY=0.05
CF_MAX_SIMILAR_USERS=30
CF_CACHE_TTL_MINUTES=15
CF_EMBEDDING_ALPHA=0.3

# ── Runtime Memory Tuning ───────────────────────────────────────────────────
UVICORN_WORKERS=1
