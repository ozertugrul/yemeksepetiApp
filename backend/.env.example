# ── PostgreSQL (Supabase) ─────────────────────────────────────────────────────
# Supabase → Settings → Database → Connection string → URI (asyncpg formatı)
DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# JSON içeriğini tek satır string'e çevir: jq -c . serviceAccountKey.json
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"..."}
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Feature Flags (rollback için) ─────────────────────────────────────────────
USE_SQL_BACKEND=true
USE_EMBEDDINGS=false

# ── API ───────────────────────────────────────────────────────────────────────
API_PREFIX=/api/v1
DEBUG=false

# ── Embedding ─────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=ozertuu/yemeksepeti-MiniLM-L12-v2
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_SEQ_LENGTH=256

# ── Collaborative Filtering ──────────────────────────────────────────────────
CF_LOOKBACK_DAYS=90
CF_MIN_SIMILARITY=0.05
CF_MAX_SIMILAR_USERS=30
CF_CACHE_TTL_MINUTES=15
CF_EMBEDDING_ALPHA=0.3

# ── Runtime Memory Tuning ───────────────────────────────────────────────────
UVICORN_WORKERS=1
