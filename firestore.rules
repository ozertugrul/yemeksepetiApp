rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ══════════════════════════════════════════════════════════════════════

    /// Current user's Firestore profile document
    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /// True if the requester is authenticated
    function isAuth() {
      return request.auth != null;
    }

    /// True if the requester is a super-admin
    function isAdmin() {
      return isAuth() && userData().role == "superAdmin";
    }

    /// True if the requester is the owner of the given restaurant
    function isOwnerOf(restaurantId) {
      return isAuth() && userData().managedRestaurantId == restaurantId;
    }

    /// True if the requester owns the restaurant that this order belongs to
    function isRestaurantOwnerOfOrder() {
      return isAuth() && userData().managedRestaurantId == resource.data.restaurantId;
    }

    /// Shorthand: admin OR restaurant owner
    function isAdminOrOwnerOf(restaurantId) {
      return isAdmin() || isOwnerOf(restaurantId);
    }

    // ══════════════════════════════════════════════════════════════════════
    // USERS  /users/{userId}
    // ══════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      // Own profile or admin can read
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());

      // Self-registration: new user creates their own document
      allow create: if isAuth() && request.auth.uid == userId;

      // Own profile or admin can update
      allow update: if isAuth() && (request.auth.uid == userId || isAdmin());

      // Only admin can delete user records
      allow delete: if isAdmin();

      // ── User sub-collections: addresses, cards, (legacy) coupons ────────
      match /addresses/{docId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
      match /cards/{docId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
      match /coupons/{docId} {
        // Legacy per-user coupon store (DiscountCoupon model)
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // ══════════════════════════════════════════════════════════════════════
    // RESTAURANTS  /restaurants/{restaurantId}
    // ══════════════════════════════════════════════════════════════════════
    match /restaurants/{restaurantId} {
      // Public listing — no auth required
      allow read: if true;

      // Admin can create any restaurant;
      // Authenticated user can create a restaurant only if they set themselves as owner
      allow create: if isAdmin() ||
        (isAuth() && request.resource.data.ownerId == request.auth.uid);

      // Admin or restaurant owner can do full updates
      // Any authenticated user can increment only the rating/order-count fields
      // (written by OrderService.submitReview / incrementSuccessfulOrders)
      allow update: if isAdminOrOwnerOf(restaurantId) ||
        (isAuth() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["averageRating", "ratingCount", "successfulOrderCount"]));

      // Only admin can delete restaurants
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // ORDERS  /orders/{orderId}
    // ══════════════════════════════════════════════════════════════════════
    match /orders/{orderId} {
      // Own order, restaurant owner, or admin can read
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        isRestaurantOwnerOfOrder() ||
        isAdmin()
      );

      // Authenticated user can create only their own order
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isAuth() && (
        // Admin: unrestricted
        isAdmin() ||
        // Restaurant owner: can update status, cancel-request handling, etc.
        isRestaurantOwnerOfOrder() ||
        // Customer: mark their own order as reviewed
        (resource.data.userId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["isReviewed"])) ||
        // Customer: submit a cancel request on their own order
        (resource.data.userId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["cancelRequested", "cancelReason", "cancelRequestedAt", "updatedAt"]))
      );

      // Only admin can hard-delete orders
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // REVIEWS  /reviews/{reviewId}
    // ══════════════════════════════════════════════════════════════════════
    match /reviews/{reviewId} {
      // Public — anyone can read reviews (displayed on restaurant pages)
      allow read: if true;

      // Authenticated user can submit a review only for themselves
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid;

      // Reviews are immutable once submitted; only admin can modify/delete
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════════
    // COUPONS  /coupons/{couponId}
    // ══════════════════════════════════════════════════════════════════════
    match /coupons/{couponId} {
      // Any authenticated user can read coupons (needed to validate at checkout
      // and to list public coupons in "Kuponlarım")
      allow read: if isAuth();

      // Admin can create any coupon.
      // Restaurant owner can create a coupon only for their own restaurant.
      allow create: if isAdmin() ||
        (isAuth() &&
          request.resource.data.createdBy == request.auth.uid &&
          isOwnerOf(request.resource.data.restaurantId));

      // Admin or the owning restaurant's owner can update/manage coupons.
      // Any authenticated user can increment usageCount (recorded after a
      // successful order — enforced client-side; Cloud Functions would be
      // the production-grade alternative).
      allow update: if isAdmin() ||
        isOwnerOf(resource.data.restaurantId) ||
        (isAuth() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["usageCount"]));

      // Admin or the creating owner can delete
      allow delete: if isAdmin() ||
        (isAuth() && resource.data.createdBy == request.auth.uid);
    }

    // ══════════════════════════════════════════════════════════════════════
    // COUPON USAGES  /couponUsages/{couponId}/users/{userId}
    // Tracks how many times each user has used a given coupon.
    // ══════════════════════════════════════════════════════════════════════
    match /couponUsages/{couponId}/users/{userId} {
      // User reads their own usage count (to enforce per-user limit)
      allow read: if isAuth() && (request.auth.uid == userId || isAdmin());

      // User writes their own usage doc (incremented after order placement)
      allow write: if isAuth() && (request.auth.uid == userId || isAdmin());
    }

  }
}

